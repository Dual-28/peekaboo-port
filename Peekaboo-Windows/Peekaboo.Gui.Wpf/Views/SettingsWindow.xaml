<Window x:Class="Peekaboo.Gui.Wpf.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Peekaboo Settings"
        Width="520" Height="580"
        Background="#1E1E1E"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="BgPrimary" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#252526"/>
        <SolidColorBrush x:Key="BgTertiary" Color="#2D2D30"/>
        <SolidColorBrush x:Key="BgHover" Color="#3E3E42"/>
        <SolidColorBrush x:Key="Accent" Color="#007ACC"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#D4D4D4"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#808080"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6A6A6A"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3E3E42"/>
        <SolidColorBrush x:Key="Success" Color="#4EC9B0"/>
        <SolidColorBrush x:Key="Error" Color="#F44747"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgTertiary}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BgTertiary}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="2"/>
            <Setter Property="TickFrequency" Value="0.1"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#252526" BorderBrush="#3E3E42" BorderThickness="0,0,0,1">
            <TextBlock Text="Settings" FontSize="16" FontWeight="SemiBold" Foreground="#D4D4D4" Margin="16,0" VerticalAlignment="Center"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
            <StackPanel>
                <!-- Provider Selection -->
                <TextBlock Text="AI Provider" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding Providers}" SelectedItem="{Binding SelectedProvider}" Margin="0,0,0,16" Height="32"/>

                <!-- Model Selection -->
                <TextBlock Text="Model" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding Models}" SelectedItem="{Binding SelectedModel}" Margin="0,0,0,16" Height="32"/>

                <!-- OpenAI API Key -->
                <TextBlock Text="OpenAI API Key" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding OpenAiApiKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16" Height="32"/>

                <!-- Anthropic API Key -->
                <TextBlock Text="Anthropic API Key" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding AnthropicApiKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16" Height="32"/>

                <!-- OpenRouter API Key -->
                <TextBlock Text="OpenRouter API Key" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding OpenRouterApiKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Height="32"/>
                <TextBlock Text="OpenRouter Model" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding OpenRouterModel, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16" Height="32"/>

                <!-- Ollama -->
                <TextBlock Text="Ollama Base URL" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding OllamaBaseUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Height="32"/>
                <TextBlock Text="Ollama Model" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding OllamaModel, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16" Height="32"/>

                <!-- Temperature -->
                <TextBlock Text="Temperature" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <Slider Value="{Binding Temperature}" Grid.Column="0"/>
                    <TextBlock Text="{Binding Temperature, StringFormat={}{0:F1}}" Grid.Column="1" HorizontalAlignment="Center" Foreground="#808080"/>
                </Grid>

                <!-- Max Tokens -->
                <TextBlock Text="Max Tokens" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding MaxTokens, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16" Height="32"/>

                <!-- Max Steps -->
                <TextBlock Text="Max Agent Steps" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding MaxSteps, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16" Height="32"/>

                <!-- Status -->
                <TextBlock Text="{Binding StatusMessage}" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#4EC9B0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Border Grid.Row="2" Background="#252526" BorderBrush="#3E3E42" BorderThickness="0,1,0,0" Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Test Connection" Background="#2D2D30" Foreground="#D4D4D4" BorderBrush="#3E3E42"
                        Command="{Binding TestConnectionCommand}" Margin="0,0,8,0"/>
                <Button Content="Save" Background="#007ACC" Foreground="White" BorderBrush="Transparent"
                        Command="{Binding SaveCommand}" Click="SaveAndClose_Click" Margin="0,0,8,0"/>
                <Button Content="Cancel" Background="#2D2D30" Foreground="#D4D4D4" BorderBrush="#3E3E42"
                        Click="Cancel_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
